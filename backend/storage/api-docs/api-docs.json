{
    "openapi": "3.0.0",
    "info": {
        "title": "Swagger API",
        "version": "1.0.0"
    },
    "paths": {
        "/api/auth/register": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Регистрация нового пользователя",
                "operationId": "2c537ca990d53cb5f9fb6cbd978245cd",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Успешная регистрация",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "data": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Вход пользователя",
                "operationId": "7f4516fd463ec0bddc660538186044a9",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Успешный вход",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "success"
                                        },
                                        "token": {
                                            "type": "string"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/logout": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Выход пользователя",
                "operationId": "100da3f6c9cb1f145c817999e8845b08",
                "responses": {
                    "200": {
                        "description": "Успешный выход",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Successfully logged out."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/import-pdf": {
            "post": {
                "tags": [
                    "Finance"
                ],
                "summary": "Импорт PDF с транзакциями",
                "description": "Загружает PDF-файл с транзакциями, сортирует данные и возвращает их вместе с итоговым резюме.",
                "operationId": "950d1a83afc1fb2aed46c770d3e29740",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "file"
                                ],
                                "properties": {
                                    "file": {
                                        "description": "PDF-файл с транзакциями.",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "sortBy": {
                                        "description": "Поле для сортировки транзакций.",
                                        "type": "string",
                                        "enum": [
                                            "date",
                                            "amount",
                                            "operation"
                                        ]
                                    },
                                    "sortOrder": {
                                        "description": "Порядок сортировки (по умолчанию - по убыванию).",
                                        "type": "string",
                                        "default": "desc",
                                        "enum": [
                                            "asc",
                                            "desc"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Успешный импорт.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "summary": {
                                            "properties": {
                                                "total_spent": {
                                                    "type": "string",
                                                    "example": "1234.56"
                                                },
                                                "total_received": {
                                                    "type": "string",
                                                    "example": "789.01"
                                                },
                                                "period": {
                                                    "type": "string",
                                                    "example": "2024-01-01 - 2024-12-31"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "transactions": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "date": {
                                                        "type": "string",
                                                        "example": "2024-01-01"
                                                    },
                                                    "amount": {
                                                        "type": "string",
                                                        "example": "500.00"
                                                    },
                                                    "operation": {
                                                        "type": "string",
                                                        "example": "Перевод"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Ошибка валидации.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The given data was invalid."
                                        },
                                        "errors": {
                                            "type": "object",
                                            "additionalProperties": {
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/analyze": {
            "post": {
                "tags": [
                    "Finance"
                ],
                "summary": "Анализ транзакций",
                "description": "Выполняет анализ переданного массива транзакций.",
                "operationId": "ce12384e62ec8f7f9746fe6bc8970ae5",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "transactions"
                                ],
                                "properties": {
                                    "transactions": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "date": {
                                                    "type": "string",
                                                    "example": "2024-01-01"
                                                },
                                                "operation": {
                                                    "type": "string",
                                                    "example": "Перевод"
                                                },
                                                "amount": {
                                                    "type": "number",
                                                    "example": 500
                                                },
                                                "details": {
                                                    "type": "string",
                                                    "example": "Описание операции"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Успешный анализ транзакций.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "most_common_operation": {
                                            "type": "string",
                                            "example": "Перевод"
                                        },
                                        "highest_transaction": {
                                            "properties": {
                                                "date": {
                                                    "type": "string",
                                                    "example": "2024-01-01"
                                                },
                                                "amount": {
                                                    "type": "number",
                                                    "example": 1500
                                                },
                                                "operation": {
                                                    "type": "string",
                                                    "example": "Пополнение"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "total_transactions": {
                                            "type": "integer",
                                            "example": 3
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Ошибка валидации.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The given data was invalid."
                                        },
                                        "errors": {
                                            "type": "object",
                                            "additionalProperties": {
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/water/set-daily-goal": {
            "post": {
                "tags": [
                    "Water"
                ],
                "summary": "Установить дневную норму воды",
                "operationId": "bd4f5085a6128a28d63f6cd1659a2229",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SetDailyGoalRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Дневная норма рассчитана и установлена.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Дневная норма рассчитана и установлена."
                                        },
                                        "data": {
                                            "properties": {
                                                "daily_goal_ml": {
                                                    "type": "integer",
                                                    "example": 2000
                                                },
                                                "glass_volume_ml": {
                                                    "type": "integer",
                                                    "example": 200
                                                },
                                                "recommended_glasses": {
                                                    "type": "integer",
                                                    "example": 10
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Ошибка валидации.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Validation error."
                                        },
                                        "errors": {
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "example": "Поле weight обязательно."
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/water/add-glass": {
            "post": {
                "tags": [
                    "Water"
                ],
                "summary": "Добавить стакан воды",
                "operationId": "b19a6dc2ebd28edd347a646ba19b70f1",
                "responses": {
                    "200": {
                        "description": "Стакан добавлен успешно.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Стакан воды добавлен."
                                        },
                                        "remaining_ml": {
                                            "type": "integer",
                                            "example": 1800
                                        },
                                        "glasses_today": {
                                            "type": "integer",
                                            "example": 1
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Неавторизованный запрос.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "User is not authenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/water/daily-stats": {
            "get": {
                "tags": [
                    "Water"
                ],
                "summary": "Получить статистику за день",
                "operationId": "86800669493e8215767ad34ecd55f73c",
                "responses": {
                    "200": {
                        "description": "Статистика за день успешно получена.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "total_consumed_ml": {
                                            "type": "integer",
                                            "example": 400
                                        },
                                        "daily_goal_ml": {
                                            "type": "integer",
                                            "example": 2000
                                        },
                                        "remaining_ml": {
                                            "type": "integer",
                                            "example": 1600
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Неавторизованный запрос.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "User is not authenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/water/overall-stats": {
            "get": {
                "tags": [
                    "Water"
                ],
                "summary": "Получить общую статистику",
                "operationId": "77cebca012641f4aece5ee18c05bb6cd",
                "responses": {
                    "200": {
                        "description": "Общая статистика успешно получена.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "total_consumed_ml": {
                                            "type": "integer",
                                            "example": 100000
                                        },
                                        "days_tracked": {
                                            "type": "integer",
                                            "example": 50
                                        },
                                        "average_daily_ml": {
                                            "type": "integer",
                                            "example": 2000
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Неавторизованный запрос.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "User is not authenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "LoginRequest": {
                "required": [
                    "login",
                    "password"
                ],
                "properties": {
                    "login": {
                        "type": "string",
                        "example": "damir"
                    },
                    "password": {
                        "type": "string",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "RegisterRequest": {
                "required": [
                    "name",
                    "login",
                    "password"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Damir"
                    },
                    "login": {
                        "type": "string",
                        "example": "damir"
                    },
                    "password": {
                        "type": "string",
                        "example": "password123"
                    }
                },
                "type": "object"
            },
            "SetDailyGoalRequest": {
                "required": [
                    "weight",
                    "height",
                    "goal",
                    "glass_volume_ml"
                ],
                "properties": {
                    "weight": {
                        "description": "Вес пользователя в кг",
                        "type": "number",
                        "format": "float",
                        "example": 70
                    },
                    "height": {
                        "description": "Рост пользователя в см",
                        "type": "number",
                        "format": "float",
                        "example": 170
                    },
                    "goal": {
                        "description": "Цель пользователя",
                        "type": "string",
                        "enum": [
                            "maintain",
                            "lose_weight"
                        ],
                        "example": "maintain"
                    },
                    "glass_volume_ml": {
                        "description": "Объем одного стакана в мл",
                        "type": "integer",
                        "example": 200
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
            "name": "Finance",
            "description": "Finance"
        },
        {
            "name": "Water",
            "description": "Water"
        }
    ]
}
